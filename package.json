{
  "name": "@creo-team/eslint-config",
  "version": "2.2.1",
  "description": "ESLint flat config: TypeScript (strict), Prettier, JSDoc, complexity, no-magic-numbers. createConfig() for options.",
  "author": "Colten Krauter <coltenkrauter>",
  "main": "dist/eslint.config.js",
  "homepage": "https://github.com/creo-team/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/creo-team/eslint-config.git"
  },
  "scripts": {
    "build": "tsc",
    "fix": "npm run lint -- --fix",
    "lint": "npx eslint .",
    "prepublishOnly": "npm run build",
    "test": "vitest run && npm run lint",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "upgrade:all": "npx npm-check-updates --upgrade --reject \"eslint|@eslint/js\" && npm install"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "creo-team",
    "flat-config",
    "typescript",
    "prettier",
    "jsdoc",
    "linting",
    "lint"
  ],
  "license": "ISC",
  "dependencies": {
    "@eslint/js": "^9.39.3",
    "@stylistic/eslint-plugin": "^5.9.0",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "files": [
    "dist/eslint.config.js",
    "dist/rules.js",
    "dist/utils.js",
    "dist/*.d.ts",
    "dist/*.js.map"
  ],
  "type": "commonjs",
  "devDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "require": "./dist/eslint.config.js",
      "default": "./dist/eslint.config.js"
    }
  }
}